<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Servir páginas estáticas independientes (AR, QR, etc.)
  RewriteRule ^Qr/cv/?$ /Qr/cv/index.html [L]

  # SPA fallback
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>
